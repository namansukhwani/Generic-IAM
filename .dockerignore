.git
.gitignore

# Environment files — containers load .env.docker instead
.env
.env.*.local

# Docker meta-files (not needed inside image)
Dockerfile
docker-compose.yml
.dockerignore

# Test utilities and coverage
coverage/
.nyc_output/
test-db.ts
test-guard.js
