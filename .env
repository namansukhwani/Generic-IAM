# .env example
# Application
APP_PORT=3000
APP_ENV=production
APP_LOG_LEVEL=info

# PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=iam
DB_USERNAME=iam_app
DB_PASSWORD=devpassword
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<secure>
REDIS_DB=0

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=iam-service
KAFKA_GROUP_ID=iam-consumers

# JWT
JWT_SECRET=<secure-256-bit-key>
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_SERVICE_TTL=3600

# SuperAdmin (bootstrap)
SUPER_ADMIN_EMAIL=superadmin@platform.com
SUPER_ADMIN_PASSWORD=<secure>

# Impersonation
IMPERSONATION_MAX_TTL=1800
